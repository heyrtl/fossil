{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://fossil.dev/schema/fossil.v1.json",
  "title": "FossilRecord",
  "description": "FOSSIL Protocol v1 — a structured reasoning failure record for AI agents",
  "type": "object",
  "required": ["id", "protocol_version", "timestamp", "agent", "situation", "failure", "resolution"],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^fossil_[a-f0-9]{12}$",
      "description": "Unique record identifier"
    },
    "protocol_version": {
      "type": "string",
      "enum": ["1.0"],
      "description": "FOSSIL protocol version"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 UTC timestamp of when the failure was recorded"
    },
    "agent": {
      "type": "object",
      "required": ["framework", "model", "task_domain"],
      "additionalProperties": false,
      "properties": {
        "framework": {
          "type": "string",
          "description": "Agent framework used e.g. langchain, crewai, claude, autogen, custom"
        },
        "model": {
          "type": "string",
          "description": "Model identifier e.g. llama-3.3-70b, gemini-2.0-flash"
        },
        "task_domain": {
          "type": "string",
          "enum": [
            "code_generation",
            "web_browsing",
            "data_analysis",
            "content_creation",
            "api_integration",
            "file_management",
            "communication",
            "planning",
            "research",
            "other"
          ]
        }
      }
    },
    "situation": {
      "type": "object",
      "required": ["description"],
      "additionalProperties": false,
      "properties": {
        "description": {
          "type": "string",
          "minLength": 10,
          "description": "Natural language description of what the agent was attempting"
        },
        "context_snapshot": {
          "type": ["string", "null"],
          "description": "Truncated, anonymized context window at time of failure"
        }
      }
    },
    "failure": {
      "type": "object",
      "required": ["type", "description", "severity"],
      "additionalProperties": false,
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "misinterpretation",
            "hallucinated_tool",
            "format_failure",
            "context_loss",
            "infinite_loop",
            "premature_termination",
            "scope_creep",
            "ambiguity_paralysis",
            "tool_misuse",
            "adversarial_input",
            "compounding_error"
          ]
        },
        "description": {
          "type": "string",
          "minLength": 10,
          "description": "What went wrong, in plain language"
        },
        "severity": {
          "type": "string",
          "enum": ["critical", "major", "minor"]
        },
        "was_irreversible": {
          "type": "boolean",
          "default": false,
          "description": "Whether the failure caused side effects that could not be undone"
        }
      }
    },
    "resolution": {
      "type": "object",
      "required": ["type", "description"],
      "additionalProperties": false,
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "prompt_change",
            "tool_fix",
            "retry",
            "human_override",
            "context_injection",
            "schema_correction",
            "step_decomposition",
            "input_sanitization"
          ]
        },
        "description": {
          "type": "string",
          "minLength": 10,
          "description": "What fixed the failure"
        },
        "verified": {
          "type": "boolean",
          "default": false,
          "description": "Whether the resolution was confirmed to work"
        },
        "time_to_resolve_minutes": {
          "type": ["integer", "null"],
          "minimum": 0
        }
      }
    },
    "shared": {
      "type": "boolean",
      "default": false,
      "description": "Whether this record is opted into the community pool"
    }
  }
}